<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.video.dazn-m3u" name="DAZN M3U" version="1.0.0" provider-name="dazn">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="resources/lib/m3u_player.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="it">DAZN Eventi - Riproduci i canali dal file M3U locale</summary>
    <description lang="it">Legge il file dazn_kodi.m3u generato dall'estrattore e riproduce i canali DAZN con inputstream.adaptive</description>
    <platform>all</platform>
    <assets>
      <icon>icon.png</icon>
    </assets>
  </extension>
</addon>
